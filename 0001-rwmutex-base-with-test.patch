diff --git a/include/rwmutex.h b/include/rwmutex.h
new file mode 100644
index 0000000..0cf73b9
--- /dev/null
+++ b/include/rwmutex.h
@@ -0,0 +1,22 @@
+#pragma once
+
+#include <spin_lock.h>
+#include <types.h>
+#include <waitqueue.h>
+
+/* rwmutex: many readers OR one writer. can block,
+ * callable in kthread context only. */
+typedef struct rwmutex {
+    spin_lock_t lock;
+    u8 live_readers;
+    u8 live_writers;
+    u8 waiting_readers;
+    wait_queue_t readers_q;
+    wait_queue_t writers_q;
+} rwmutex_t;
+
+void rwmutex_init(rwmutex_t *rw);
+void rwmutex_read_acquire(rwmutex_t *rw);
+void rwmutex_read_release(rwmutex_t *rw);
+void rwmutex_write_acquire(rwmutex_t *rw);
+void rwmutex_write_release(rwmutex_t *rw);
diff --git a/kernel/core.mk b/kernel/core.mk
index 43c9735..33048c5 100644
--- a/kernel/core.mk
+++ b/kernel/core.mk
@@ -14,6 +14,7 @@ CORE_KERNEL_OBJS += spin_lock.o
 CORE_KERNEL_OBJS += waitqueue.o
 CORE_KERNEL_OBJS += sched.o
 CORE_KERNEL_OBJS += mutex.o
+CORE_KERNEL_OBJS += rwmutex.o
