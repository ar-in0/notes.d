 $(call add_src, $(CONFIG_SMP_KTESTS), TESTS_OBJS, smp_atomics_tests.o)
 $(call add_src, $(CONFIG_SMP_KTESTS), TESTS_OBJS, smp_ipi_tests.o)
 $(call add_src, $(CONFIG_SMP_KTESTS), TESTS_OBJS, smp_async_work_tests.o)
